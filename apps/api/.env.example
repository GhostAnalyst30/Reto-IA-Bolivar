OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_TUTOR=google/gemma-4-31b-it:free
LLM_MODEL_DIRECTOR=google/gemma-4-31b-it:free
LLM_MODEL_PATH=openai/gpt-oss-20b:free
# CSV de modelos gratis OpenRouter (máx. LLM_MAX_OPENROUTER_ATTEMPTS intentos)
LLM_OPENROUTER_FREE_MODELS=google/gemma-4-31b-it:free,openai/gpt-oss-20b:free,nvidia/nemotron-nano-9b-v2:free,google/gemma-4-26b-a4b-it:free,openrouter/free
LLM_MAX_OPENROUTER_ATTEMPTS=5
# Cascade: OpenRouter free → Hugging Face → Gemini (último hop IA antes de psicólogo)
LLM_PROVIDER_ORDER=openrouter,huggingface,gemini
LLM_HTTP_TIMEOUT_S=15
LLM_MODEL_GEMINI=gemini-2.0-flash
GEMINI_API_KEY=
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta
LITELLM_API_BASE=
LITELLM_API_KEY=
