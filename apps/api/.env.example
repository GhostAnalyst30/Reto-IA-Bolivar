YOUTUBE_API_KEY=
SCRAPER_ENABLED=false
ALLOWED_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000
INTERNAL_REGISTER_KEY=genera-un-secreto-largo-aqui
